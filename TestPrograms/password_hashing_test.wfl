// Password hashing builtins test
// Demonstrates Argon2id, bcrypt, scrypt and PBKDF2 password hashing and
// verification. Unlike sha256/wflhash, these are slow, salted and designed
// specifically for storing passwords safely.

display "=== Password Hashing Test ==="
display ""

store pass_count as 0
store fail_count as 0

// === Generic hash_password / verify_password (Argon2id default) ===
display "1. hash_password / verify_password (recommended default)"

store stored as hash_password of "correct horse battery staple"
store good as verify_password of "correct horse battery staple" and stored
check if good is yes:
    display "PASS: correct password verifies"
    change pass_count to pass_count plus 1
otherwise:
    display "FAIL: correct password did not verify"
    change fail_count to fail_count plus 1
end check

store bad as verify_password of "wrong password" and stored
check if bad is no:
    display "PASS: wrong password rejected"
    change pass_count to pass_count plus 1
otherwise:
    display "FAIL: wrong password was accepted"
    change fail_count to fail_count plus 1
end check

// A fresh random salt means the same password hashes differently each time.
store stored_again as hash_password of "correct horse battery staple"
check if stored is not stored_again:
    display "PASS: each hash uses a unique random salt"
    change pass_count to pass_count plus 1
otherwise:
    display "FAIL: hashes were identical (no salt?)"
    change fail_count to fail_count plus 1
end check
display ""

// === Per-algorithm roundtrips ===
display "2. Argon2"
store argon_hash as argon2_hash of "argon-secret"
store argon_ok as argon2_verify of "argon-secret" and argon_hash
check if argon_ok is yes:
    display "PASS: argon2 roundtrip"
    change pass_count to pass_count plus 1
otherwise:
    display "FAIL: argon2 roundtrip"
    change fail_count to fail_count plus 1
end check

display "3. bcrypt"
store bcrypt_stored as bcrypt_hash of "bcrypt-secret"
store bcrypt_ok as bcrypt_verify of "bcrypt-secret" and bcrypt_stored
check if bcrypt_ok is yes:
    display "PASS: bcrypt roundtrip"
    change pass_count to pass_count plus 1
otherwise:
    display "FAIL: bcrypt roundtrip"
    change fail_count to fail_count plus 1
end check

display "4. scrypt"
store scrypt_stored as scrypt_hash of "scrypt-secret"
store scrypt_ok as scrypt_verify of "scrypt-secret" and scrypt_stored
check if scrypt_ok is yes:
    display "PASS: scrypt roundtrip"
    change pass_count to pass_count plus 1
otherwise:
    display "FAIL: scrypt roundtrip"
    change fail_count to fail_count plus 1
end check

display "5. PBKDF2"
store pbkdf2_stored as pbkdf2_hash of "pbkdf2-secret"
store pbkdf2_ok as pbkdf2_verify of "pbkdf2-secret" and pbkdf2_stored
check if pbkdf2_ok is yes:
    display "PASS: pbkdf2 roundtrip"
    change pass_count to pass_count plus 1
otherwise:
    display "FAIL: pbkdf2 roundtrip"
    change fail_count to fail_count plus 1
end check
display ""

// === verify_password auto-detects the algorithm from the stored hash ===
display "6. verify_password auto-detection"
store detect_ok as verify_password of "bcrypt-secret" and bcrypt_stored
check if detect_ok is yes:
    display "PASS: verify_password auto-detected bcrypt"
    change pass_count to pass_count plus 1
otherwise:
    display "FAIL: verify_password could not detect bcrypt"
    change fail_count to fail_count plus 1
end check
display ""

display "=== Results: " with pass_count with " passed, " with fail_count with " failed ==="
check if fail_count is 0:
    display "All password hashing tests passed!"
otherwise:
    display "SOME TESTS FAILED"
end check
