// ==============================================================================
// Comprehensive Router Tests
// ==============================================================================
// Complete integration tests for all router features:
// - Module routing with context variables
// - Static file serving
// - Route parameters
// - HTTP method filtering
// - Priority-based matching
// - Multiple route types in one router
// - Edge cases and error scenarios
// ==============================================================================

display "=== Comprehensive Router Tests ==="

// Load the router library
load module from "../lib/router.wfl"

// Test 1: Complete router setup with all route types
display "Test 1: Complete router setup with all route types"
create new Router as full_router:
    initialize()
end

// Add module routes
call full_router.get with "/" and "test_routes/test_module.wfl"
call full_router.get with "/api/status" and "test_routes/test_module.wfl"
call full_router.post with "/api/data" and "test_routes/param_test.wfl"

// Add parameterized routes
store param_config as {}
store param_config["path"] as "/users/:id"
store param_config["method"] as "GET"
store param_config["type"] as "module"
store param_config["module"] as "test_routes/param_test.wfl"
call full_router.add_route with param_config

// Add static directory
call full_router.add_static_directory with "/static" and "test_public"

// Add specific static file
store static_config as {}
store static_config["path"] as "/favicon.ico"
store static_config["type"] as "static"
store static_config["file"] as "test_public/test.html"
call full_router.add_route with static_config

store total_routes as length of full_router.routes
check if total_routes is equal to 6:
    display "  ✓ All 6 routes registered successfully"
otherwise:
    display "  ✗ Should have 6 routes, got: " with total_routes
end check

// Test 2: Route matching order and priority
display "Test 2: Route matching order and priority"

// Test home route
store home_req as {}
store home_req["path"] as "/"
store home_req["method"] as "GET"
store home_req["_raw"] as {}

store home_info as call full_router.handle_request with home_req
check if home_info["matched"] is true:
    check if home_info["handler_type"] is equal to "module":
        display "  ✓ Home route matched as module"
    otherwise:
        display "  ✗ Home route should be module type"
    end check
otherwise:
    display "  ✗ Home route should match"
end check

// Test API route
store api_req as {}
store api_req["path"] as "/api/status"
store api_req["method"] as "GET"
store api_req["_raw"] as {}

store api_info as call full_router.handle_request with api_req
check if api_info["matched"] is true:
    display "  ✓ API route matched"
otherwise:
    display "  ✗ API route should match"
end check

// Test static directory route
store static_req as {}
store static_req["path"] as "/static/test.html"
store static_req["method"] as "GET"
store static_req["_raw"] as {}

store static_info as call full_router.handle_request with static_req
check if static_info["matched"] is true:
    check if static_info["handler_type"] is equal to "static":
        display "  ✓ Static directory route matched"
    otherwise:
        display "  ✗ Static route handler type should be static"
    end check
otherwise:
    display "  ✗ Static directory route should match"
end check

// Test 3: Parameter extraction in full context
display "Test 3: Parameter extraction in full context"

store user_req as {}
store user_req["path"] as "/users/456"
store user_req["method"] as "GET"
store user_req["_raw"] as {}

store user_info as call full_router.handle_request with user_req
check if user_info["matched"] is true:
    display "  ✓ Parameterized user route matched"

    store params as user_info["params"]
    check if params contains "id":
        check if params["id"] is equal to "456":
            display "  ✓ User ID parameter extracted correctly (456)"
        otherwise:
            display "  ✗ User ID should be 456, got: " with params["id"]
        end check
    otherwise:
        display "  ✗ Parameters should contain 'id'"
    end check
otherwise:
    display "  ✗ Parameterized user route should match"
end check

// Test 4: HTTP method filtering in full context
display "Test 4: HTTP method filtering in full context"

// Test correct method (POST)
store post_req as {}
store post_req["path"] as "/api/data"
store post_req["method"] as "POST"
store post_req["_raw"] as {}

store post_info as call full_router.handle_request with post_req
check if post_info["matched"] is true:
    display "  ✓ POST method matched correctly"
otherwise:
    display "  ✗ POST method should match"
end check

// Test wrong method (GET on POST-only route)
store wrong_method_req as {}
store wrong_method_req["path"] as "/api/data"
store wrong_method_req["method"] as "GET"
store wrong_method_req["_raw"] as {}

store wrong_info as call full_router.handle_request with wrong_method_req
check if wrong_info["matched"] is true:
    // Could match /api/status instead
    display "  Note: Matched different route (expected behavior)"
otherwise:
    display "  Note: No match for GET /api/data (expected)"
end check

// Test 5: MIME type detection for various file types
display "Test 5: MIME type detection for various file types"

store mime_tests as [
    {"file": "test.html", "expected": "text/html"},
    {"file": "style.css", "expected": "text/css"},
    {"file": "app.js", "expected": "application/javascript"},
    {"file": "data.json", "expected": "application/json"},
    {"file": "image.png", "expected": "image/png"},
    {"file": "photo.jpg", "expected": "image/jpeg"},
    {"file": "icon.svg", "expected": "image/svg+xml"}
]

store passed_mime_tests as 0
store total_mime_tests as length of mime_tests

count from 0 to total_mime_tests minus 1 as idx:
    store test_case as item at idx of mime_tests
    store test_file as test_case["file"]
    store expected_mime as test_case["expected"]

    store detected_mime as call full_router.get_mime_type with test_file

    check if detected_mime is equal to expected_mime:
        store passed_mime_tests as passed_mime_tests plus 1
    end check
end count

check if passed_mime_tests is equal to total_mime_tests:
    display "  ✓ All MIME types detected correctly (" with passed_mime_tests with "/" with total_mime_tests with ")"
otherwise:
    display "  ✗ MIME type detection: " with passed_mime_tests with "/" with total_mime_tests with " passed"
end check

// Test 6: Edge cases - empty paths, special characters
display "Test 6: Edge cases and special scenarios"

// Test root path
store root_req as {}
store root_req["path"] as "/"
store root_req["method"] as "GET"
store root_req["_raw"] as {}

store root_info as call full_router.handle_request with root_req
check if root_info["matched"] is true:
    display "  ✓ Root path (/) handled correctly"
otherwise:
    display "  ✗ Root path should match"
end check

// Test non-existent route
store missing_req as {}
store missing_req["path"] as "/nonexistent/route"
store missing_req["method"] as "GET"
store missing_req["_raw"] as {}

store missing_info as call full_router.handle_request with missing_req
check if missing_info["matched"] is false:
    display "  ✓ Non-existent route returns not found"
otherwise:
    display "  ✗ Non-existent route should not match"
end check

// Test very long path
store long_path as "/very/long/path/with/many/segments/that/goes/on/and/on"
store long_req as {}
store long_req["path"] as long_path
store long_req["method"] as "GET"
store long_req["_raw"] as {}

store long_info as call full_router.handle_request with long_req
check if long_info["matched"] is false:
    display "  ✓ Very long path handled without errors"
otherwise:
    display "  Note: Long path unexpectedly matched a route"
end check

// Test 7: Multiple routers operating independently
display "Test 7: Multiple routers operating independently"

create new Router as router_a:
    initialize()
end

create new Router as router_b:
    initialize()
end

call router_a.get with "/test" and "test_routes/test_module.wfl"
call router_b.get with "/test" and "test_routes/param_test.wfl"

store routes_a as length of router_a.routes
store routes_b as length of router_b.routes

check if routes_a is equal to 1:
    check if routes_b is equal to 1:
        display "  ✓ Multiple routers operate independently"
    otherwise:
        display "  ✗ Router B should have 1 route"
    end check
otherwise:
    display "  ✗ Router A should have 1 route"
end check

// Verify they route to different modules
store test_req_a as {}
store test_req_a["path"] as "/test"
store test_req_a["method"] as "GET"
store test_req_a["_raw"] as {}

store info_a as call router_a.handle_request with test_req_a
store info_b as call router_b.handle_request with test_req_a

check if info_a["module_path"] is not equal to info_b["module_path"]:
    display "  ✓ Each router routes to its own configured module"
otherwise:
    display "  ✗ Routers should route to different modules"
end check

// Test 8: Wildcard pattern matching in full context
display "Test 8: Wildcard pattern matching"

create new Router as wildcard_router:
    initialize()
end

store wildcard_config as {}
store wildcard_config["path"] as "/files/*"
store wildcard_config["type"] as "directory"
store wildcard_config["directory"] as "test_public"
call wildcard_router.add_route with wildcard_config

store wildcard_req as {}
store wildcard_req["path"] as "/files/anything/here.html"
store wildcard_req["method"] as "GET"
store wildcard_req["_raw"] as {}

store wildcard_info as call wildcard_router.handle_request with wildcard_req
check if wildcard_info["matched"] is true:
    display "  ✓ Wildcard pattern matched successfully"
otherwise:
    display "  ✗ Wildcard pattern should match"
end check

// Test 9: Complex parameterized routes
display "Test 9: Complex parameterized routes"

create new Router as complex_router:
    initialize()
end

store complex_config as {}
store complex_config["path"] as "/api/:version/users/:userId/posts/:postId"
store complex_config["type"] as "module"
store complex_config["module"] as "test_routes/param_test.wfl"
call complex_router.add_route with complex_config

store complex_req as {}
store complex_req["path"] as "/api/v2/users/789/posts/101"
store complex_req["method"] as "GET"
store complex_req["_raw"] as {}

store complex_info as call complex_router.handle_request with complex_req
check if complex_info["matched"] is true:
    display "  ✓ Complex parameterized route matched"

    store complex_params as complex_info["params"]
    store params_valid as true

    check if complex_params contains "version":
        check if complex_params["version"] is not equal to "v2":
            store params_valid as false
        end check
    otherwise:
        store params_valid as false
    end check

    check if complex_params contains "userId":
        check if complex_params["userId"] is not equal to "789":
            store params_valid as false
        end check
    otherwise:
        store params_valid as false
    end check

    check if complex_params contains "postId":
        check if complex_params["postId"] is not equal to "101":
            store params_valid as false
        end check
    otherwise:
        store params_valid as false
    end check

    check if params_valid is true:
        display "  ✓ All complex parameters extracted correctly"
    otherwise:
        display "  ✗ Some parameters not extracted correctly"
    end check
otherwise:
    display "  ✗ Complex parameterized route should match"
end check

// Test 10: Performance - many routes
display "Test 10: Performance with many routes"

create new Router as perf_router:
    initialize()
end

// Add 20 routes
count from 1 to 20 as i:
    store route_path as "/route" with i
    call perf_router.get with route_path and "test_routes/test_module.wfl"
end count

store perf_routes_count as length of perf_router.routes
check if perf_routes_count is equal to 20:
    display "  ✓ Performance test: 20 routes registered"

    // Test matching last route
    store perf_req as {}
    store perf_req["path"] as "/route20"
    store perf_req["method"] as "GET"
    store perf_req["_raw"] as {}

    store perf_info as call perf_router.handle_request with perf_req
    check if perf_info["matched"] is true:
        display "  ✓ Performance test: Route lookup successful with 20 routes"
    otherwise:
        display "  ✗ Should match route20"
    end check
otherwise:
    display "  ✗ Should have 20 routes, got: " with perf_routes_count
end check

display ""
display "=== Comprehensive Router Tests Complete ==="
display ""
display "Summary:"
display "- All core routing features tested"
display "- Module loading verified"
display "- Static file serving verified"
display "- Parameter extraction verified"
display "- HTTP method filtering verified"
display "- MIME type detection verified"
display "- Edge cases handled"
display "- Performance acceptable"
