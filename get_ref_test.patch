    pub fn is_sync_auto_call(&self, name: &str) -> Option<bool> {
        // Check local scope first
        if let Some(value) = self.values.get(name) {
            match value {
                Value::Function(func) => return Some(func.params.is_empty()), // Zero-arg user functions auto-call (async)
                Value::NativeFunction(_, _) => return Some(false), // Native functions evaluate sync
                _ => return Some(false),
            }
        }

